# Copy to .env.local and fill in. NEVER commit real secrets.
# Local values are printed by `supabase start`.

# Public (browser-safe) — anon key is gated by RLS, not a secret in the usual sense.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — must NEVER reach the browser or the repo.
SUPABASE_SERVICE_ROLE_KEY=

# Used by the RLS test harness (/tests/rls) and CI.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
