# This machine's network corrupts large TLS streams under concurrency
# (registry tarballs fail mid-download with bad-record-MAC). A single socket
# plus aggressive retries reliably gets installs through. Remove once the
# underlying AV-HTTPS-scanning / NIC-offload issue is fixed.
maxsockets=1
fetch-retries=8
fetch-retry-mintimeout=2000
fetch-retry-maxtimeout=60000
fetch-timeout=300000
